# Copy to `.env` at the repo root (see .gitignore). Used by `docker compose` and `go run` (via godotenv + os.ExpandEnv).

APP_ENV=development
API_PORT=8080
# Local API listen address (`go run`). Use :8081 if Docker API already uses 8080.
HTTP_ADDR=:8080

# ── Postgres ──
# Set POSTGRES_PASSWORD to a strong value (e.g. `openssl rand -base64 24`). Never commit `.env`.
# GUI (TablePlus, DBeaver): Host = POSTGRES_HOST, Port = POSTGRES_PORT, User = POSTGRES_USER, etc.
POSTGRES_HOST=127.0.0.1
POSTGRES_USER=spa
POSTGRES_PASSWORD=
POSTGRES_DB=spa_booking
POSTGRES_PORT=5433

REDIS_PORT=6379

# API + tools on the host: use published Postgres port (POSTGRES_PORT), not 5432 inside the container.
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
REDIS_URL=redis://127.0.0.1:${REDIS_PORT}/0

JWT_SECRET=replace-with-a-long-random-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_2FA_TEMP_TTL=5m
OAUTH_STATE_TTL=10m
TOTP_ISSUER=SpaBooking

# Google OAuth (optional — leave empty to disable). Redirect must match Google Cloud console.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/oauth/google/callback
