# Optional overrides for the Go API (loaded after repo root `.env` when both exist).
# See `../../.env.example` for POSTGRES_* and full template.

HTTP_ADDR=:8080
# Or rely on root .env DATABASE_URL (uses ${POSTGRES_USER} etc.):
# DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
DATABASE_URL=postgres://spa:spa_secret@127.0.0.1:5433/spa_booking?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0
APP_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
