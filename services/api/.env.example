# Optional overrides for the Go API (loaded after repo root `.env` when both exist).
# See `../../.env.example` for POSTGRES_* and full template.

HTTP_ADDR=:8080
# DATABASE_URL is normally set in root `.env` (with ${POSTGRES_USER}:${POSTGRES_PASSWORD}...).
# Override here only if needed; never commit real credentials.
# Same shape as root `.env.example` — only ${VAR} (Go expands via os.ExpandEnv; defaults live in POSTGRES_* or defaultDatabaseURL()).
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0
APP_ENV=development
JWT_SECRET=replace-with-a-long-random-secret
