# Copy to .env.local (Next.js) or .env per app — see apps/README.md
# API base URL (browser must reach this host; use your LAN IP for phones / other machines)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket base (optional; some apps build ws:// from API host)
NEXT_PUBLIC_WS_URL=ws://localhost:8080
